generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Service {
  MIDI
  SOIR
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  DECLINED
  CANCELLED
  NO_SHOW
}

model Reservation {
  id              String            @id @default(cuid())
  name            String
  phone           String
  email           String?
  reservationDate DateTime
  reservationTime String
  service         Service
  partySize       Int
  message         String?
  status          ReservationStatus @default(PENDING)
  source          String            @default("website")
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([reservationDate, service, status])
}

model ServiceCapacity {
  id              String   @id @default(cuid())
  reservationDate DateTime
  service         Service
  capacity        Int
  isClosed        Boolean  @default(false)
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([reservationDate, service])
}

model ServiceSchedule {
  id        String   @id @default(cuid())
  weekday   Int
  service   Service
  capacity  Int
  isClosed  Boolean  @default(false)
  openTime  String?
  closeTime String?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([weekday, service])
}

model SiteContent {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BistroEvent {
  id          String   @id @default(cuid())
  title       String
  eventDate   DateTime
  eventTime   String?
  summary     String
  details     String?
  imageUrl    String?
  ctaLabel    String?
  ctaUrl      String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([eventDate, isPublished])
}

model GalleryPhoto {
  id          String   @id @default(cuid())
  title       String
  category    String
  alt         String?
  imageUrl    String
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, isPublished, sortOrder])
}
