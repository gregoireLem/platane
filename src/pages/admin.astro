---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';

const apiUrl = site.reservationApiUrl;
---

<BaseLayout title="Administration" description="Gestion des réservations Au Platane.">
  <section class="section admin-page">
    <div class="admin-heading" data-reveal>
      <p class="eyebrow">Administration</p>
      <h1>Gérer les réservations.</h1>
      <p class="lead">
        Consultez les demandes, confirmez les tables et ajustez les capacités du midi et du soir.
      </p>
    </div>

    <div class="admin-grid">
      <section class="admin-card" data-reveal>
        <div class="admin-card__header">
          <h2>Accès</h2>
          <p>Le token admin reste enregistré uniquement dans ce navigateur.</p>
        </div>

        <form class="admin-token-form" data-admin-token-form data-api-url={apiUrl}>
          <div class="field">
            <label for="admin-token">Token admin</label>
            <input
              id="admin-token"
              name="token"
              type="password"
              placeholder="Collez le token du backend"
            />
          </div>
          <div class="admin-token-form__actions">
            <button class="button button--primary" type="submit">Enregistrer le token</button>
            <button class="button button--secondary" type="button" data-admin-token-clear>
              Effacer
            </button>
          </div>
          <p class="admin-inline-feedback" data-admin-token-feedback aria-live="polite"></p>
        </form>
      </section>

      <section class="admin-card" data-reveal>
        <div class="admin-card__header">
          <h2>Filtres</h2>
          <p>Utilisez la vue globale, puis zoomez sur une date si vous devez ajuster les capacites.</p>
        </div>

        <form class="admin-filters" data-admin-filters>
          <div class="admin-filter-presets">
            <button class="button button--ghost" type="button" data-filter-preset="all">Tout voir</button>
            <button class="button button--ghost" type="button" data-filter-preset="today">Aujourd'hui</button>
            <button class="button button--ghost" type="button" data-filter-preset="tomorrow">Demain</button>
          </div>

          <div class="field-grid">
            <div class="field">
              <label for="admin-date">Date</label>
              <input id="admin-date" name="date" type="date" />
            </div>
            <div class="field">
              <label for="admin-service">Service</label>
              <select id="admin-service" name="service">
                <option value="">Tous</option>
                <option value="midi">Midi</option>
                <option value="soir">Soir</option>
              </select>
            </div>
          </div>

          <div class="field-grid">
            <div class="field">
              <label for="admin-status">Statut</label>
              <select id="admin-status" name="status">
                <option value="">Tous</option>
                <option value="PENDING">En attente</option>
                <option value="CONFIRMED">Confirmée</option>
                <option value="DECLINED">Refusée</option>
                <option value="CANCELLED">Annulée</option>
                <option value="NO_SHOW">No-show</option>
              </select>
            </div>

            <div class="field">
              <label for="admin-sort">Tri</label>
              <select id="admin-sort" name="sort">
                <option value="date-asc">Date la plus proche</option>
                <option value="date-desc">Date la plus lointaine</option>
                <option value="created-desc">Demande la plus récente</option>
                <option value="party-desc">Plus grandes tables</option>
              </select>
            </div>
          </div>

          <div class="field">
            <label for="admin-search">Recherche</label>
            <input
              id="admin-search"
              name="search"
              type="search"
              placeholder="Nom, téléphone, email, note ou message"
            />
          </div>

          <div class="admin-token-form__actions">
            <button class="button button--primary" type="submit">Actualiser</button>
          </div>
        </form>
      </section>
    </div>

    <section class="admin-card" data-reveal>
      <div class="admin-card__header">
        <h2>Ajouter une réservation</h2>
        <p>Saisissez à la main une demande reçue par téléphone, sur place ou par message.</p>
      </div>

      <form class="admin-manual-form" data-admin-manual-form>
        <div class="field-grid">
          <div class="field">
            <label for="manual-date">Date</label>
            <input id="manual-date" name="reservationDate" type="date" required />
          </div>
          <div class="field">
            <label for="manual-time">Heure</label>
            <input id="manual-time" name="reservationTime" type="time" required />
          </div>
        </div>

        <div class="field-grid">
          <div class="field">
            <label for="manual-service">Service</label>
            <select id="manual-service" name="service">
              <option value="midi">Midi</option>
              <option value="soir" selected>Soir</option>
            </select>
          </div>
          <div class="field">
            <label for="manual-party">Nombre de personnes</label>
            <input id="manual-party" name="partySize" type="number" min="1" max="20" value="2" required />
          </div>
        </div>

        <div class="field-grid">
          <div class="field">
            <label for="manual-name">Nom</label>
            <input id="manual-name" name="name" type="text" placeholder="Nom du client" required />
          </div>
          <div class="field">
            <label for="manual-phone">Téléphone</label>
            <input id="manual-phone" name="phone" type="tel" placeholder="06..." required />
          </div>
        </div>

        <div class="field-grid">
          <div class="field">
            <label for="manual-email">Email</label>
            <input id="manual-email" name="email" type="email" placeholder="Optionnel" />
          </div>
          <div class="field">
            <label for="manual-source">Source</label>
            <select id="manual-source" name="source">
              <option value="telephone">Téléphone</option>
              <option value="sur-place">Sur place</option>
              <option value="sms">SMS</option>
              <option value="instagram">Instagram</option>
              <option value="autre">Autre</option>
            </select>
          </div>
        </div>

        <div class="field-grid">
          <div class="field">
            <label for="manual-status">Statut</label>
            <select id="manual-status" name="status">
              <option value="CONFIRMED" selected>Confirmée</option>
              <option value="PENDING">En attente</option>
              <option value="DECLINED">Refusée</option>
              <option value="CANCELLED">Annulée</option>
              <option value="NO_SHOW">No-show</option>
            </select>
          </div>
          <div class="field">
            <label for="manual-notes">Notes internes</label>
            <input id="manual-notes" name="notes" type="text" placeholder="Allergie, terrasse, poussette..." />
          </div>
        </div>

        <div class="field">
          <label for="manual-message">Message</label>
          <textarea id="manual-message" name="message" rows="3" placeholder="Demande client, précision d'horaire, occasion..."></textarea>
        </div>

        <div class="admin-token-form__actions">
          <button class="button button--primary" type="submit">Ajouter la réservation</button>
        </div>
        <p class="admin-inline-feedback" data-admin-manual-feedback aria-live="polite"></p>
      </form>
    </section>

    <section class="admin-card" data-reveal>
      <div class="admin-card__header">
        <h2>Planning mensuel</h2>
        <p>Repérez rapidement les jours calmes, les jours chargés et les services complets.</p>
      </div>

      <div class="admin-planning-toolbar">
        <div class="field">
          <label for="admin-month">Mois</label>
          <input id="admin-month" type="month" data-admin-month />
        </div>
      </div>
      <div class="admin-calendar" data-admin-calendar></div>
    </section>

    <section class="admin-card" data-reveal>
      <div class="admin-card__header">
        <h2>Capacités du jour</h2>
        <p>Ajustez le nombre de places par service ou marquez un service complet.</p>
      </div>

      <div class="admin-capacity-grid" data-admin-capacities></div>
      <p class="admin-inline-feedback" data-admin-capacity-feedback aria-live="polite"></p>
    </section>

    <section class="admin-card" data-reveal>
      <div class="admin-card__header">
        <h2>Réservations</h2>
        <p>Vue planning globale, puis cartes détaillées par date et par service.</p>
      </div>

      <div class="admin-summary" data-admin-summary></div>
      <div class="admin-overview" data-admin-overview></div>
      <p class="admin-inline-feedback" data-admin-reservations-feedback aria-live="polite"></p>
      <div class="admin-reservations" data-admin-reservations></div>
    </section>
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const tokenStorageKey = 'au-platane-admin-token';
    const statusLabels = {
      PENDING: 'En attente',
      CONFIRMED: 'Confirmee',
      DECLINED: 'Refusee',
      CANCELLED: 'Annulee',
      NO_SHOW: 'No-show'
    };
    const serviceLabels = {
      midi: 'Midi',
      soir: 'Soir',
      MIDI: 'Midi',
      SOIR: 'Soir'
    };

    const initAdminPage = () => {
      const tokenForm = document.querySelector('[data-admin-token-form]');
      const filtersForm = document.querySelector('[data-admin-filters]');
      const capacitiesNode = document.querySelector('[data-admin-capacities]');
      const summaryNode = document.querySelector('[data-admin-summary]');
      const overviewNode = document.querySelector('[data-admin-overview]');
      const calendarNode = document.querySelector('[data-admin-calendar]');
      const reservationsNode = document.querySelector('[data-admin-reservations]');
      const tokenFeedback = document.querySelector('[data-admin-token-feedback]');
      const capacityFeedback = document.querySelector('[data-admin-capacity-feedback]');
      const reservationsFeedback = document.querySelector('[data-admin-reservations-feedback]');
      const manualForm = document.querySelector('[data-admin-manual-form]');
      const manualFeedback = document.querySelector('[data-admin-manual-feedback]');

      if (
        !(tokenForm instanceof HTMLFormElement) ||
        !(filtersForm instanceof HTMLFormElement) ||
        !(capacitiesNode instanceof HTMLElement) ||
        !(summaryNode instanceof HTMLElement) ||
        !(overviewNode instanceof HTMLElement) ||
        !(calendarNode instanceof HTMLElement) ||
        !(reservationsNode instanceof HTMLElement) ||
        !(tokenFeedback instanceof HTMLElement) ||
        !(capacityFeedback instanceof HTMLElement) ||
        !(reservationsFeedback instanceof HTMLElement) ||
        !(manualForm instanceof HTMLFormElement) ||
        !(manualFeedback instanceof HTMLElement)
      ) {
        return;
      }

      const apiRoot = tokenForm.dataset.apiUrl;
      if (!apiRoot) return;

      const tokenInput = tokenForm.querySelector('#admin-token');
      const clearButton = tokenForm.querySelector('[data-admin-token-clear]');
      const dateInput = filtersForm.querySelector('#admin-date');
      const serviceInput = filtersForm.querySelector('#admin-service');
      const statusInput = filtersForm.querySelector('#admin-status');
      const sortInput = filtersForm.querySelector('#admin-sort');
      const searchInput = filtersForm.querySelector('#admin-search');
      const monthInput = document.querySelector('[data-admin-month]');

      if (
        !(tokenInput instanceof HTMLInputElement) ||
        !(clearButton instanceof HTMLButtonElement) ||
        !(dateInput instanceof HTMLInputElement) ||
        !(serviceInput instanceof HTMLSelectElement) ||
        !(statusInput instanceof HTMLSelectElement) ||
        !(sortInput instanceof HTMLSelectElement) ||
        !(searchInput instanceof HTMLInputElement) ||
        !(monthInput instanceof HTMLInputElement)
      ) {
        return;
      }

      const state = {
        token: localStorage.getItem(tokenStorageKey) ?? '',
        reservations: [],
        filteredReservations: []
      };

      const today = () => new Date().toISOString().slice(0, 10);
      const tomorrow = () => {
        const date = new Date();
        date.setDate(date.getDate() + 1);
        return date.toISOString().slice(0, 10);
      };
      const currentMonth = () => new Date().toISOString().slice(0, 7);

      const formatDay = (value) =>
        new Intl.DateTimeFormat('fr-FR', {
          weekday: 'short',
          day: 'numeric',
          month: 'short'
        }).format(new Date(`${value}T12:00:00`));

      const formatDateTime = (value) =>
        new Intl.DateTimeFormat('fr-FR', {
          day: '2-digit',
          month: '2-digit',
          hour: '2-digit',
          minute: '2-digit'
        }).format(new Date(value));

      const setFeedback = (node, message, tone = '') => {
        node.textContent = message;
        node.dataset.tone = tone;
      };

      const authHeaders = () => ({
        'Content-Type': 'application/json',
        'x-admin-token': state.token
      });

      const renderSummary = () => {
        if (!state.filteredReservations.length) {
          summaryNode.innerHTML = '<p class="admin-empty">Aucune reservation pour ce filtre.</p>';
          return;
        }

        const counters = state.filteredReservations.reduce(
          (acc, reservation) => {
            acc.total += 1;
            acc.seats += reservation.partySize;
            acc[reservation.status] = (acc[reservation.status] ?? 0) + 1;
            acc.dates.add(reservation.reservationDate.slice(0, 10));
            return acc;
          },
          {
            total: 0,
            seats: 0,
            PENDING: 0,
            CONFIRMED: 0,
            DECLINED: 0,
            CANCELLED: 0,
            NO_SHOW: 0,
            dates: new Set()
          }
        );

        summaryNode.innerHTML = `
          <div class="admin-summary-card">
            <strong>${counters.total}</strong>
            <span>reservations</span>
          </div>
          <div class="admin-summary-card">
            <strong>${counters.seats}</strong>
            <span>couverts</span>
          </div>
          <div class="admin-summary-card">
            <strong>${counters.PENDING}</strong>
            <span>en attente</span>
          </div>
          <div class="admin-summary-card">
            <strong>${counters.CONFIRMED}</strong>
            <span>confirmees</span>
          </div>
          <div class="admin-summary-card">
            <strong>${counters.dates.size}</strong>
            <span>jour(s) affiché(s)</span>
          </div>
        `;
      };

      const renderOverview = () => {
        if (!state.filteredReservations.length) {
          overviewNode.innerHTML = '';
          return;
        }

        const dayMap = new Map();
        for (const reservation of state.filteredReservations) {
          const dateKey = reservation.reservationDate.slice(0, 10);
          const current = dayMap.get(dateKey) ?? { total: 0, seats: 0, pending: 0, confirmed: 0 };
          current.total += 1;
          current.seats += reservation.partySize;
          if (reservation.status === 'PENDING') current.pending += 1;
          if (reservation.status === 'CONFIRMED') current.confirmed += 1;
          dayMap.set(dateKey, current);
        }

        overviewNode.innerHTML = Array.from(dayMap.entries())
          .map(
            ([dateKey, counts]) => `
              <article class="admin-overview-card">
                <div>
                  <h3>${formatDay(dateKey)}</h3>
                  <p>${counts.total} reservation(s) • ${counts.seats} couvert(s)</p>
                </div>
                <div class="admin-overview-card__badges">
                  <span class="admin-status-badge" data-status="PENDING">${counts.pending} attente</span>
                  <span class="admin-status-badge" data-status="CONFIRMED">${counts.confirmed} confirmees</span>
                </div>
              </article>
            `
          )
          .join('');
      };

      const renderCalendar = () => {
        const monthValue = monthInput.value || currentMonth();
        const [year, month] = monthValue.split('-').map(Number);
        const firstDay = new Date(year, month - 1, 1);
        const lastDay = new Date(year, month, 0);
        const startWeekday = (firstDay.getDay() + 6) % 7;
        const totalDays = lastDay.getDate();
        const cells = [];
        const reservationsByDate = new Map();

        for (const reservation of state.reservations) {
          const dateKey = reservation.reservationDate.slice(0, 10);
          if (!dateKey.startsWith(monthValue)) continue;

          const current = reservationsByDate.get(dateKey) ?? {
            total: 0,
            seats: 0,
            services: {
              midi: { total: 0, seats: 0 },
              soir: { total: 0, seats: 0 }
            }
          };

          const serviceKey = reservation.service.toLowerCase();
          current.total += 1;
          current.seats += reservation.partySize;
          current.services[serviceKey].total += 1;
          current.services[serviceKey].seats += reservation.partySize;
          reservationsByDate.set(dateKey, current);
        }

        for (let i = 0; i < startWeekday; i += 1) {
          cells.push('<div class="admin-calendar__cell admin-calendar__cell--empty"></div>');
        }

        for (let day = 1; day <= totalDays; day += 1) {
          const date = new Date(year, month - 1, day);
          const dateKey = date.toISOString().slice(0, 10);
          const dayData = reservationsByDate.get(dateKey);

          cells.push(`
            <button class="admin-calendar__cell" type="button" data-calendar-date="${dateKey}">
              <div class="admin-calendar__cell-top">
                <strong>${day}</strong>
                ${dayData ? `<span>${dayData.total} resa</span>` : '<span>Libre</span>'}
              </div>
              <div class="admin-calendar__services">
                <div class="admin-calendar__service">
                  <span>Midi</span>
                  <strong>${dayData?.services.midi.total ?? 0}</strong>
                  <small>${dayData?.services.midi.seats ?? 0} cvt</small>
                </div>
                <div class="admin-calendar__service">
                  <span>Soir</span>
                  <strong>${dayData?.services.soir.total ?? 0}</strong>
                  <small>${dayData?.services.soir.seats ?? 0} cvt</small>
                </div>
              </div>
            </button>
          `);
        }

        calendarNode.innerHTML = `
          <div class="admin-calendar__weekdays">
            <span>Lun</span>
            <span>Mar</span>
            <span>Mer</span>
            <span>Jeu</span>
            <span>Ven</span>
            <span>Sam</span>
            <span>Dim</span>
          </div>
          <div class="admin-calendar__grid">${cells.join('')}</div>
        `;
      };

      const applyClientFilters = () => {
        const search = searchInput.value.trim().toLowerCase();
        const selectedDate = dateInput.value;
        const selectedService = serviceInput.value;
        const selectedStatus = statusInput.value;

        const filtered = state.reservations.filter((reservation) => {
          const dateKey = reservation.reservationDate.slice(0, 10);
          const serviceKey = reservation.service.toLowerCase();

          if (selectedDate && dateKey !== selectedDate) return false;
          if (selectedService && serviceKey !== selectedService) return false;
          if (selectedStatus && reservation.status !== selectedStatus) return false;

          if (!search) return true;

          const haystack = [
            reservation.name,
            reservation.phone,
            reservation.email,
            reservation.message,
            reservation.notes,
            reservation.reservationTime,
            dateKey,
            serviceLabels[reservation.service]
          ]
            .filter(Boolean)
            .join(' ')
            .toLowerCase();

          return haystack.includes(search);
        });

        const sortValue = sortInput.value;
        filtered.sort((left, right) => {
          const leftDate = `${left.reservationDate.slice(0, 10)}T${left.reservationTime}`;
          const rightDate = `${right.reservationDate.slice(0, 10)}T${right.reservationTime}`;

          if (sortValue === 'date-desc') return rightDate.localeCompare(leftDate);
          if (sortValue === 'created-desc') return new Date(right.createdAt) - new Date(left.createdAt);
          if (sortValue === 'party-desc') return right.partySize - left.partySize || leftDate.localeCompare(rightDate);
          return leftDate.localeCompare(rightDate);
        });

        state.filteredReservations = filtered;
      };

      const renderReservations = () => {
        if (!state.filteredReservations.length) {
          reservationsNode.innerHTML = '<p class="admin-empty">Aucune reservation trouvee.</p>';
          return;
        }

        const groups = new Map();
        for (const reservation of state.filteredReservations) {
          const dateKey = reservation.reservationDate.slice(0, 10);
          const serviceKey = reservation.service.toLowerCase();
          const groupKey = `${dateKey}-${serviceKey}`;
          const bucket = groups.get(groupKey) ?? {
            dateKey,
            serviceKey,
            seats: 0,
            items: []
          };
          bucket.seats += reservation.partySize;
          bucket.items.push(reservation);
          groups.set(groupKey, bucket);
        }

        reservationsNode.innerHTML = Array.from(groups.values())
          .map(
            (group) => `
              <section class="admin-reservation-group">
                <div class="admin-reservation-group__header">
                  <div>
                    <h3>${formatDay(group.dateKey)} • ${serviceLabels[group.serviceKey]}</h3>
                    <p>${group.items.length} reservation(s) • ${group.seats} couvert(s)</p>
                  </div>
                  <button class="button button--ghost" type="button" data-copy-date="${group.dateKey}">
                    Voir les capacites du jour
                  </button>
                </div>

                <div class="admin-reservation-list">
                  ${group.items
                    .map(
                      (reservation) => `
                        <article class="admin-reservation-card">
                          <div class="admin-reservation-card__top">
                            <div>
                              <h3>${reservation.name}</h3>
                              <p>${reservation.partySize} couvert(s) • ${serviceLabels[reservation.service]} • ${reservation.reservationTime}</p>
                              <p>${reservation.phone}${reservation.email ? ` • ${reservation.email}` : ''}</p>
                            </div>
                            <span class="admin-status-badge" data-status="${reservation.status}">
                              ${statusLabels[reservation.status]}
                            </span>
                          </div>

                          <div class="admin-reservation-card__meta">
                            <span>Demandée le ${formatDateTime(reservation.createdAt)}</span>
                          </div>

                          <p class="admin-reservation-card__message">${reservation.message || 'Aucun message.'}</p>

                          <div class="field-grid">
                            <div class="field">
                              <label for="status-${reservation.id}">Statut</label>
                              <select id="status-${reservation.id}" data-reservation-status>
                                ${Object.entries(statusLabels)
                                  .map(
                                    ([value, label]) =>
                                      `<option value="${value}"${reservation.status === value ? ' selected' : ''}>${label}</option>`
                                  )
                                  .join('')}
                              </select>
                            </div>

                            <div class="field">
                              <label for="notes-${reservation.id}">Notes</label>
                              <textarea id="notes-${reservation.id}" rows="3" data-reservation-notes>${reservation.notes ?? ''}</textarea>
                            </div>
                          </div>

                          <div class="admin-reservation-card__actions">
                            <button class="button button--primary" type="button" data-save-reservation data-id="${reservation.id}">
                              Enregistrer
                            </button>
                          </div>
                        </article>
                      `
                    )
                    .join('')}
                </div>
              </section>
            `
          )
          .join('');
      };

      const renderCapacities = async () => {
        if (!dateInput.value) {
          capacitiesNode.innerHTML = '<p class="admin-empty">Choisissez une date pour gerer les capacites.</p>';
          return;
        }

        try {
          const results = await Promise.all(
            ['midi', 'soir'].map(async (service) => {
              const response = await fetch(
                `${apiRoot}/reservations/availability?date=${encodeURIComponent(dateInput.value)}&service=${service}`
              );

              if (!response.ok) throw new Error('capacity');
              return response.json();
            })
          );

          capacitiesNode.innerHTML = results
            .map(
              (serviceData) => `
                <form class="admin-capacity-card" data-capacity-form data-service="${serviceData.service}">
                  <div class="admin-capacity-card__top">
                    <div>
                      <h3>${serviceLabels[serviceData.service]}</h3>
                      <p>${serviceData.remainingSeats} place(s) restantes sur ${serviceData.capacity}</p>
                    </div>
                    <span class="admin-status-badge" data-status="${serviceData.remainingSeats <= 0 || serviceData.isClosed ? 'DECLINED' : 'CONFIRMED'}">
                      ${serviceData.remainingSeats <= 0 || serviceData.isClosed ? 'Complet' : 'Disponible'}
                    </span>
                  </div>

                  <div class="field-grid">
                    <div class="field">
                      <label>Capacite</label>
                      <input type="number" min="1" max="500" value="${serviceData.capacity}" data-capacity-value />
                    </div>
                    <label class="admin-checkbox">
                      <input type="checkbox" data-capacity-closed ${serviceData.isClosed ? 'checked' : ''} />
                      <span>Fermer ce service</span>
                    </label>
                  </div>

                  <div class="field">
                    <label>Note</label>
                    <textarea rows="2" data-capacity-note>${serviceData.note ?? ''}</textarea>
                  </div>

                  <div class="admin-reservation-card__actions">
                    <button class="button button--secondary" type="submit">Mettre a jour</button>
                  </div>
                </form>
              `
            )
            .join('');
        } catch (_error) {
          capacitiesNode.innerHTML = '<p class="admin-empty">Impossible de charger les capacites.</p>';
        }
      };

      const loadReservations = async () => {
        if (!state.token) {
          setFeedback(tokenFeedback, 'Ajoutez le token admin pour charger les reservations.', 'warning');
          reservationsNode.innerHTML = '<p class="admin-empty">Token manquant.</p>';
          summaryNode.innerHTML = '';
          return;
        }

        const params = new URLSearchParams();
        if (dateInput.value) params.set('date', dateInput.value);
        if (serviceInput.value) params.set('service', serviceInput.value);
        if (statusInput.value) params.set('status', statusInput.value);

        setFeedback(reservationsFeedback, 'Chargement des reservations...', '');

        try {
          const response = await fetch(`${apiRoot}/admin/reservations?${params.toString()}`, {
            headers: authHeaders()
          });

          if (!response.ok) {
            throw new Error('admin');
          }

          state.reservations = await response.json();
          applyClientFilters();
          renderSummary();
          renderOverview();
          renderCalendar();
          renderReservations();
          setFeedback(
            reservationsFeedback,
            `${state.filteredReservations.length} reservation(s) affichee(s) sur ${state.reservations.length} chargee(s).`,
            'success'
          );
        } catch (_error) {
          state.reservations = [];
          state.filteredReservations = [];
          renderSummary();
          renderOverview();
          renderCalendar();
          renderReservations();
          setFeedback(reservationsFeedback, 'Impossible de charger les reservations. Verifiez le token admin.', 'error');
        }
      };

      tokenInput.value = state.token;
      monthInput.value = currentMonth();
      const manualDateInput = manualForm.querySelector('#manual-date');
      const manualTimeInput = manualForm.querySelector('#manual-time');
      if (manualDateInput instanceof HTMLInputElement) manualDateInput.value = today();
      if (manualTimeInput instanceof HTMLInputElement) manualTimeInput.value = '19:30';

      tokenForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        state.token = tokenInput.value.trim();

        if (!state.token) {
          localStorage.removeItem(tokenStorageKey);
          setFeedback(tokenFeedback, 'Token vide.', 'warning');
          return;
        }

        localStorage.setItem(tokenStorageKey, state.token);
        setFeedback(tokenFeedback, 'Token enregistre sur ce navigateur.', 'success');
        await renderCapacities();
        await loadReservations();
      });

      clearButton.addEventListener('click', () => {
        state.token = '';
        tokenInput.value = '';
        localStorage.removeItem(tokenStorageKey);
        setFeedback(tokenFeedback, 'Token efface.', 'warning');
      });

      filtersForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        await renderCapacities();
        await loadReservations();
      });

      filtersForm.addEventListener('input', () => {
        if (!state.reservations.length) return;
        applyClientFilters();
        renderSummary();
        renderOverview();
        renderCalendar();
        renderReservations();
      });

      filtersForm.addEventListener('click', async (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        const button = target.closest('[data-filter-preset]');
        if (!(button instanceof HTMLButtonElement)) return;

        const preset = button.dataset.filterPreset;
        if (preset === 'all') {
          dateInput.value = '';
        } else if (preset === 'today') {
          dateInput.value = today();
        } else if (preset === 'tomorrow') {
          dateInput.value = tomorrow();
        }

        await renderCapacities();
        await loadReservations();
      });

      monthInput.addEventListener('change', () => {
        renderCalendar();
      });

      capacitiesNode.addEventListener('submit', async (event) => {
        const target = event.target;
        if (!(target instanceof HTMLFormElement) || !target.matches('[data-capacity-form]')) return;
        event.preventDefault();

        if (!state.token) {
          setFeedback(capacityFeedback, 'Token admin requis pour modifier les capacites.', 'error');
          return;
        }

        const service = target.dataset.service;
        const capacityInput = target.querySelector('[data-capacity-value]');
        const closedInput = target.querySelector('[data-capacity-closed]');
        const noteInput = target.querySelector('[data-capacity-note]');

        if (
          !service ||
          !(capacityInput instanceof HTMLInputElement) ||
          !(closedInput instanceof HTMLInputElement) ||
          !(noteInput instanceof HTMLTextAreaElement)
        ) {
          return;
        }

        try {
          const response = await fetch(`${apiRoot}/admin/capacities`, {
            method: 'PUT',
            headers: authHeaders(),
            body: JSON.stringify({
              date: dateInput.value,
              service,
              capacity: Number(capacityInput.value),
              isClosed: closedInput.checked,
              note: noteInput.value.trim()
            })
          });

          if (!response.ok) throw new Error('capacity');

          setFeedback(capacityFeedback, `Capacite du ${serviceLabels[service]} mise a jour.`, 'success');
          await renderCapacities();
        } catch (_error) {
          setFeedback(capacityFeedback, 'Impossible de mettre a jour la capacite.', 'error');
        }
      });

      manualForm.addEventListener('submit', async (event) => {
        event.preventDefault();

        if (!state.token) {
          setFeedback(manualFeedback, 'Token admin requis pour ajouter une reservation.', 'error');
          return;
        }

        const formData = new FormData(manualForm);
        setFeedback(manualFeedback, 'Ajout de la reservation...', '');

        try {
          const response = await fetch(`${apiRoot}/admin/reservations`, {
            method: 'POST',
            headers: authHeaders(),
            body: JSON.stringify({
              name: formData.get('name')?.toString().trim(),
              phone: formData.get('phone')?.toString().trim(),
              email: formData.get('email')?.toString().trim(),
              reservationDate: formData.get('reservationDate')?.toString().trim(),
              reservationTime: formData.get('reservationTime')?.toString().trim(),
              service: formData.get('service')?.toString().trim(),
              partySize: formData.get('partySize')?.toString().trim(),
              message: formData.get('message')?.toString().trim(),
              notes: formData.get('notes')?.toString().trim(),
              source: formData.get('source')?.toString().trim(),
              status: formData.get('status')?.toString().trim()
            })
          });

          if (!response.ok) {
            throw new Error('manual');
          }

          manualForm.reset();
          if (manualDateInput instanceof HTMLInputElement) manualDateInput.value = today();
          if (manualTimeInput instanceof HTMLInputElement) manualTimeInput.value = '19:30';
          setFeedback(manualFeedback, 'Reservation ajoutée.', 'success');
          await renderCapacities();
          await loadReservations();
        } catch (_error) {
          setFeedback(manualFeedback, "Impossible d'ajouter la reservation.", 'error');
        }
      });

      calendarNode.addEventListener('click', async (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;

        const calendarDateButton = target.closest('[data-calendar-date]');
        if (!(calendarDateButton instanceof HTMLButtonElement)) return;
        const clickedDate = calendarDateButton.dataset.calendarDate;
        if (!clickedDate) return;

        dateInput.value = clickedDate;
        await renderCapacities();
        await loadReservations();
      });

      reservationsNode.addEventListener('click', async (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;

        const focusDateButton = target.closest('[data-copy-date]');
        if (focusDateButton instanceof HTMLButtonElement) {
          const focusDate = focusDateButton.dataset.copyDate;
          if (focusDate) {
            dateInput.value = focusDate;
            await renderCapacities();
            await loadReservations();
          }
          return;
        }

        const button = target.closest('[data-save-reservation]');
        if (!(button instanceof HTMLButtonElement)) return;

        if (!state.token) {
          setFeedback(reservationsFeedback, 'Token admin requis pour modifier une reservation.', 'error');
          return;
        }

        const card = button.closest('.admin-reservation-card');
        const reservationId = button.dataset.id;
        const statusSelect = card?.querySelector('[data-reservation-status]');
        const notesInput = card?.querySelector('[data-reservation-notes]');

        if (
          !reservationId ||
          !(statusSelect instanceof HTMLSelectElement) ||
          !(notesInput instanceof HTMLTextAreaElement)
        ) {
          return;
        }

        try {
          const response = await fetch(`${apiRoot}/admin/reservations/${reservationId}/status`, {
            method: 'PATCH',
            headers: authHeaders(),
            body: JSON.stringify({
              status: statusSelect.value,
              notes: notesInput.value.trim()
            })
          });

          if (!response.ok) throw new Error('reservation');

          setFeedback(reservationsFeedback, 'Reservation mise a jour.', 'success');
          await renderCapacities();
          await loadReservations();
        } catch (_error) {
          setFeedback(reservationsFeedback, 'Impossible de mettre a jour la reservation.', 'error');
        }
      });

      renderCapacities();
      if (state.token) {
        setFeedback(tokenFeedback, 'Token charge depuis ce navigateur.', 'success');
        loadReservations();
      }
    };

    document.addEventListener('astro:page-load', initAdminPage);
    initAdminPage();
  })();
</script>
