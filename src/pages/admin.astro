---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';

const apiUrl = site.reservationApiUrl;
---

<BaseLayout title="Administration" description="Outil de communication Au Platane.">
  <section class="section admin-page">
    <div class="admin-heading" data-reveal>
      <div class="admin-brand-bar">
        <img src="/brand/logo-alt-black.jpg" alt="" />
        <div>
          <p class="eyebrow">Administration</p>
          <p class="admin-brand-bar__tagline">Outil de communication Au Platane</p>
        </div>
      </div>
      <h1>Faire vivre le bistrot en ligne.</h1>
      <p class="lead">
        Carte, suggestions, événements et galerie : l’admin sert à raconter ce qui se passe au
        Platane, sans devenir un deuxième logiciel de caisse.
      </p>
    </div>

    <section class="admin-card" data-reveal>
      <div class="admin-card__header">
        <h2>Accès</h2>
        <p>Connectez-vous avec le compte admin pour modifier les contenus publics.</p>
      </div>

      <form class="admin-login-form" data-admin-login-form data-api-url={apiUrl}>
        <div class="field-grid">
          <div class="field">
            <label for="admin-username">Identifiant</label>
            <input id="admin-username" name="username" type="text" autocomplete="username" />
          </div>
          <div class="field">
            <label for="admin-password">Mot de passe</label>
            <input id="admin-password" name="password" type="password" autocomplete="current-password" />
          </div>
        </div>
        <div class="admin-login-form__actions">
          <button class="button button--primary" type="submit">Se connecter</button>
          <button class="button button--secondary" type="button" data-admin-logout disabled>
            Se déconnecter
          </button>
        </div>
        <p class="admin-inline-feedback" data-admin-login-feedback aria-live="polite"></p>
      </form>
    </section>

    <section class="admin-card admin-dashboard-intro" data-admin-dashboard hidden>
      <div class="admin-card__header">
        <h2>Tableau de bord éditorial</h2>
        <p>Choisissez l’espace à mettre à jour. Les changements sont visibles sur le site sans rebuild.</p>
      </div>
      <div class="admin-view-switcher" data-admin-view-switcher>
        <button class="button button--primary" type="button" data-admin-view-target="menu">Carte & menus</button>
        <button class="button button--secondary" type="button" data-admin-view-target="events">Événements</button>
        <button class="button button--secondary" type="button" data-admin-view-target="suggestions">Suggestions</button>
        <button class="button button--secondary" type="button" data-admin-view-target="gallery">Galerie</button>
      </div>
    </section>

    <section class="admin-view-panel" data-admin-view="menu" hidden>
      <section class="admin-card">
        <div class="admin-card__header">
          <h2>Modifier la carte et les menus</h2>
          <p>Une saisie simple, pensée comme une ardoise : un titre de rubrique avec <strong>:</strong>, puis un plat par ligne.</p>
        </div>

        <form class="admin-editor-form" data-menu-form>
          <div class="field-grid">
            <div class="field">
              <label for="menu-title">Titre</label>
              <input id="menu-title" name="title" type="text" />
            </div>
            <div class="field">
              <label for="menu-period">Période</label>
              <input id="menu-period" name="period" type="text" />
            </div>
          </div>
          <div class="field-grid">
            <div class="field">
              <label for="menu-updated">Mis à jour le</label>
              <input id="menu-updated" name="updatedAt" type="text" placeholder="16 mai 2026" />
            </div>
            <div class="field">
              <label for="menu-intro">Introduction</label>
              <input id="menu-intro" name="intro" type="text" />
            </div>
          </div>
          <div class="field">
            <label for="menu-formulas">Formules</label>
            <textarea id="menu-formulas" name="formulas" rows="5" placeholder="Le midi : Formule du jour maison&#10;Le soir : Assiettes à partager"></textarea>
          </div>
          <div class="field">
            <label for="menu-sections">Carte</label>
            <textarea id="menu-sections" name="sections" rows="16" placeholder={`Entrées:\nŒuf mayonnaise fermier\nGaspacho de tomates anciennes\n\nPlats:\nLe Burger du Platane\nBœuf mijoté au vin rouge`}></textarea>
          </div>
          <div class="field">
            <label for="menu-notes">Notes</label>
            <textarea id="menu-notes" name="notes" rows="4" placeholder="Une note par ligne"></textarea>
          </div>
          <div class="admin-form-actions">
            <button class="button button--primary" type="submit">Publier la carte</button>
          </div>
          <p class="admin-inline-feedback" data-menu-feedback aria-live="polite"></p>
        </form>
      </section>
    </section>

    <section class="admin-view-panel" data-admin-view="events" hidden>
      <div class="admin-grid">
        <section class="admin-card">
          <div class="admin-card__header">
            <h2>Créer un événement</h2>
            <p>Photo, date, texte court. Le badge “Ce week-end” est généré automatiquement.</p>
          </div>
          <form class="admin-editor-form" data-event-form>
            <div class="field">
              <label for="event-title">Titre</label>
              <input id="event-title" name="title" type="text" required />
            </div>
            <div class="field-grid">
              <div class="field">
                <label for="event-date">Date</label>
                <input id="event-date" name="eventDate" type="date" required />
              </div>
              <div class="field">
                <label for="event-time">Horaire</label>
                <input id="event-time" name="eventTime" type="text" placeholder="20h30" />
              </div>
            </div>
            <div class="field">
              <label for="event-summary">Résumé</label>
              <textarea id="event-summary" name="summary" rows="3" required></textarea>
            </div>
            <div class="field">
              <label for="event-image">Photo</label>
              <input id="event-image" name="image" type="file" accept="image/*" />
            </div>
            <div class="admin-form-actions">
              <button class="button button--primary" type="submit">Publier l’événement</button>
            </div>
            <p class="admin-inline-feedback" data-event-feedback aria-live="polite"></p>
          </form>
        </section>

        <section class="admin-card">
          <div class="admin-card__header">
            <h2>Événements publiés</h2>
            <p>Les prochains événements remontent automatiquement sur la page d’accueil.</p>
          </div>
          <div class="admin-content-list" data-events-list></div>
        </section>
      </div>
    </section>

    <section class="admin-view-panel" data-admin-view="suggestions" hidden>
      <section class="admin-card">
        <div class="admin-card__header">
          <h2>Suggestions du jour</h2>
          <p>Plat du jour, boisson et bière pression du moment.</p>
        </div>
        <form class="admin-editor-form" data-suggestions-form>
          <div class="field-grid">
            <div class="field">
              <label for="suggestion-dish">Plat du jour</label>
              <input id="suggestion-dish" name="dish" type="text" />
            </div>
            <div class="field">
              <label for="suggestion-drink">Boisson du moment</label>
              <input id="suggestion-drink" name="drink" type="text" />
            </div>
          </div>
          <div class="field-grid">
            <div class="field">
              <label for="suggestion-beer">Bière pression</label>
              <input id="suggestion-beer" name="beer" type="text" />
            </div>
            <div class="field">
              <label for="suggestion-updated">Mis à jour le</label>
              <input id="suggestion-updated" name="updatedAt" type="text" placeholder="Aujourd’hui" />
            </div>
          </div>
          <div class="admin-form-actions">
            <button class="button button--primary" type="submit">Publier les suggestions</button>
          </div>
          <p class="admin-inline-feedback" data-suggestions-feedback aria-live="polite"></p>
        </form>
      </section>
    </section>

    <section class="admin-view-panel" data-admin-view="gallery" hidden>
      <div class="admin-grid">
        <section class="admin-card">
          <div class="admin-card__header">
            <h2>Ajouter une photo</h2>
            <p>Plats, terrasse, soirées, fournisseurs, village, équipe.</p>
          </div>
          <form class="admin-editor-form" data-gallery-form>
            <div class="field">
              <label for="gallery-title">Titre</label>
              <input id="gallery-title" name="title" type="text" required />
            </div>
            <div class="field">
              <label for="gallery-category">Catégorie</label>
              <select id="gallery-category" name="category">
                <option value="Plats">Plats</option>
                <option value="Terrasse">Terrasse</option>
                <option value="Soirées">Soirées</option>
                <option value="Fournisseurs locaux">Fournisseurs locaux</option>
                <option value="Village">Village</option>
                <option value="Équipe">Équipe</option>
              </select>
            </div>
            <div class="field">
              <label for="gallery-image">Photo</label>
              <input id="gallery-image" name="image" type="file" accept="image/*" required />
            </div>
            <div class="admin-form-actions">
              <button class="button button--primary" type="submit">Ajouter à la galerie</button>
            </div>
            <p class="admin-inline-feedback" data-gallery-feedback aria-live="polite"></p>
          </form>
        </section>

        <section class="admin-card">
          <div class="admin-card__header">
            <h2>Galerie publiée</h2>
            <p>Les dernières photos enrichissent l’accueil.</p>
          </div>
          <div class="admin-content-list admin-content-list--gallery" data-gallery-list></div>
        </section>
      </div>
    </section>
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const initAdminPage = () => {
      const loginForm = document.querySelector('[data-admin-login-form]');
      if (!(loginForm instanceof HTMLFormElement) || loginForm.dataset.bound === 'true') return;
      loginForm.dataset.bound = 'true';

      const apiRoot = loginForm.dataset.apiUrl;
      const dashboard = document.querySelector('[data-admin-dashboard]');
      const loginFeedback = document.querySelector('[data-admin-login-feedback]');
      const logoutButton = loginForm.querySelector('[data-admin-logout]');
      const loginButton = loginForm.querySelector('button[type="submit"]');
      const usernameInput = loginForm.querySelector('#admin-username');
      const passwordInput = loginForm.querySelector('#admin-password');
      const viewButtons = Array.from(document.querySelectorAll('[data-admin-view-target]'));
      const viewPanels = Array.from(document.querySelectorAll('[data-admin-view]'));
      const menuForm = document.querySelector('[data-menu-form]');
      const eventForm = document.querySelector('[data-event-form]');
      const suggestionsForm = document.querySelector('[data-suggestions-form]');
      const galleryForm = document.querySelector('[data-gallery-form]');
      const eventsList = document.querySelector('[data-events-list]');
      const galleryList = document.querySelector('[data-gallery-list]');

      if (
        !apiRoot ||
        !(dashboard instanceof HTMLElement) ||
        !(loginFeedback instanceof HTMLElement) ||
        !(logoutButton instanceof HTMLButtonElement) ||
        !(loginButton instanceof HTMLButtonElement) ||
        !(usernameInput instanceof HTMLInputElement) ||
        !(passwordInput instanceof HTMLInputElement) ||
        !(menuForm instanceof HTMLFormElement) ||
        !(eventForm instanceof HTMLFormElement) ||
        !(suggestionsForm instanceof HTMLFormElement) ||
        !(galleryForm instanceof HTMLFormElement) ||
        !(eventsList instanceof HTMLElement) ||
        !(galleryList instanceof HTMLElement)
      ) {
        return;
      }

      const state = {
        isAuthenticated: false,
        content: null
      };

      const setFeedback = (node, message, tone = '') => {
        node.textContent = message;
        node.dataset.tone = tone;
      };

      const adminFetch = (path, options = {}) =>
        fetch(`${apiRoot}${path}`, {
          ...options,
          credentials: 'include',
          headers: {
            'Content-Type': 'application/json',
            ...(options.headers ?? {})
          }
        });

      const setAuthenticated = (isAuthenticated, username = '') => {
        state.isAuthenticated = isAuthenticated;
        dashboard.hidden = !isAuthenticated;
        usernameInput.disabled = false;
        loginButton.disabled = false;
        logoutButton.disabled = !isAuthenticated;
        passwordInput.value = '';
        viewPanels.forEach((panel) => {
          if (panel instanceof HTMLElement) panel.hidden = !isAuthenticated || panel.dataset.adminView !== 'menu';
        });
        if (isAuthenticated) setFeedback(loginFeedback, `Connecté${username ? ` en tant que ${username}` : ''}.`, 'success');
      };

      const setActiveView = (view) => {
        viewPanels.forEach((panel) => {
          if (panel instanceof HTMLElement) panel.hidden = panel.dataset.adminView !== view;
        });
        viewButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          const active = button.dataset.adminViewTarget === view;
          button.classList.toggle('button--primary', active);
          button.classList.toggle('button--secondary', !active);
        });
      };

      const eventDateValue = (value) => String(value ?? '').slice(0, 10);
      const lineValue = (value) => String(value ?? '').trim();
      const splitLines = (value) => value.split('\n').map((line) => line.trim()).filter(Boolean);
      const field = (form, name) => form.elements.namedItem(name);
      const inputValue = (form, name) => {
        const node = field(form, name);
        return node instanceof HTMLInputElement || node instanceof HTMLTextAreaElement || node instanceof HTMLSelectElement
          ? node.value
          : '';
      };
      const setInputValue = (form, name, value) => {
        const node = field(form, name);
        if (node instanceof HTMLInputElement || node instanceof HTMLTextAreaElement || node instanceof HTMLSelectElement) {
          node.value = value;
        }
      };

      const formulasToText = (items) =>
        (items ?? []).map((item) => `${item.name}${item.description ? ` : ${item.description}` : ''}`).join('\n');

      const sectionsToText = (sections) =>
        (sections ?? [])
          .map((section) => `${section.title}:\n${section.items.map((item) => item.description ? `${item.name} - ${item.description}` : item.name).join('\n')}`)
          .join('\n\n');

      const parseFormulas = (value) =>
        splitLines(value).map((line) => {
          const parts = line.includes('|') ? line.split('|') : line.split(':');
          const [name = '', priceOrDescription = '', descriptionValue = ''] = parts.map(lineValue);
          const description = descriptionValue || priceOrDescription;
          const price = descriptionValue ? priceOrDescription : '';
          return { name, price, description };
        }).filter((item) => item.name);

      const parseMenuLine = (line) => {
        if (line.includes('|')) {
          const [name = '', price = '', description = ''] = line.split('|').map(lineValue);
          return { name, price, description };
        }

        const [name = '', description = ''] = line.split(/\s+-\s+/, 2).map(lineValue);
        return { name, price: '', description };
      };

      const parseSections = (value) => {
        const sections = [];
        let current = null;

        splitLines(value).forEach((line) => {
          if (line.endsWith(':')) {
            current = { title: line.slice(0, -1).trim(), items: [] };
            sections.push(current);
            return;
          }

          if (!current) {
            current = { title: line, items: [] };
            sections.push(current);
            return;
          }

          const item = parseMenuLine(line);
          if (item.name) current.items.push(item);
        });

        return sections.filter((section) => section.title && section.items.length);
      };

      const readImageAsDataUrl = (input) =>
        new Promise((resolve, reject) => {
          const file = input.files?.[0];
          if (!file) {
            resolve('');
            return;
          }
          if (file.size > 1_800_000) {
            reject(new Error('image-size'));
            return;
          }
          const reader = new FileReader();
          reader.addEventListener('load', () => resolve(String(reader.result ?? '')));
          reader.addEventListener('error', () => reject(new Error('image-read')));
          reader.readAsDataURL(file);
        });

      const fillForms = (content) => {
        setInputValue(menuForm, 'title', content.menu.title);
        setInputValue(menuForm, 'period', content.menu.period);
        setInputValue(menuForm, 'updatedAt', content.menu.updatedAt);
        setInputValue(menuForm, 'intro', content.menu.intro);
        setInputValue(menuForm, 'formulas', formulasToText(content.menu.formulas));
        setInputValue(menuForm, 'sections', sectionsToText(content.menu.sections));
        setInputValue(menuForm, 'notes', (content.menu.notes ?? []).join('\n'));

        setInputValue(suggestionsForm, 'dish', content.suggestions.dish);
        setInputValue(suggestionsForm, 'drink', content.suggestions.drink);
        setInputValue(suggestionsForm, 'beer', content.suggestions.beer);
        setInputValue(suggestionsForm, 'updatedAt', content.suggestions.updatedAt);
      };

      const renderEvents = (events) => {
        eventsList.innerHTML = events.length
          ? events
              .map(
                (event) => `
                  <article class="admin-content-item">
                    ${event.imageUrl ? `<img src="${event.imageUrl}" alt="" />` : ''}
                    <div>
                      <span>${eventDateValue(event.eventDate)}${event.eventTime ? ` · ${event.eventTime}` : ''}</span>
                      <strong>${event.title}</strong>
                      <p>${event.summary}</p>
                    </div>
                    <button class="button button--ghost" type="button" data-delete-event="${event.id}">Supprimer</button>
                  </article>
                `
              )
              .join('')
          : '<p class="admin-empty">Aucun événement pour le moment.</p>';
      };

      const renderGallery = (gallery) => {
        galleryList.innerHTML = gallery.length
          ? gallery
              .map(
                (photo) => `
                  <article class="admin-content-item">
                    <img src="${photo.imageUrl}" alt="" />
                    <div>
                      <span>${photo.category}</span>
                      <strong>${photo.title}</strong>
                    </div>
                    <button class="button button--ghost" type="button" data-delete-gallery="${photo.id}">Supprimer</button>
                  </article>
                `
              )
              .join('')
          : '<p class="admin-empty">Aucune photo publiée.</p>';
      };

      const loadContent = async () => {
        const response = await adminFetch('/admin/content');
        if (!response.ok) throw new Error('content');
        state.content = await response.json();
        fillForms(state.content);
        renderEvents(state.content.events);
        renderGallery(state.content.gallery);
      };

      const loadContentOrWarn = async () => {
        try {
          await loadContent();
          return true;
        } catch (_error) {
          setFeedback(
            loginFeedback,
            'Connecté, mais le backend contenu n’est pas encore déployé. Redéployez Railway sur le dernier commit.',
            'warning'
          );
          return false;
        }
      };

      const editorialPayload = () => ({
        menu: {
          title: inputValue(menuForm, 'title').trim(),
          period: inputValue(menuForm, 'period').trim(),
          updatedAt: inputValue(menuForm, 'updatedAt').trim(),
          intro: inputValue(menuForm, 'intro').trim(),
          formulas: parseFormulas(inputValue(menuForm, 'formulas')),
          sections: parseSections(inputValue(menuForm, 'sections')),
          notes: splitLines(inputValue(menuForm, 'notes'))
        },
        suggestions: {
          dish: inputValue(suggestionsForm, 'dish').trim(),
          drink: inputValue(suggestionsForm, 'drink').trim(),
          beer: inputValue(suggestionsForm, 'beer').trim(),
          updatedAt: inputValue(suggestionsForm, 'updatedAt').trim()
        }
      });

      loginForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        try {
          const response = await adminFetch('/admin/login', {
            method: 'POST',
            body: JSON.stringify({
              username: usernameInput.value.trim(),
              password: passwordInput.value
            })
          });
          if (!response.ok) {
            setAuthenticated(false);
            setFeedback(loginFeedback, 'Identifiant ou mot de passe incorrect.', 'error');
            return;
          }
          setAuthenticated(true, usernameInput.value.trim());
          await loadContentOrWarn();
        } catch (_error) {
          setAuthenticated(false);
          setFeedback(loginFeedback, 'Impossible de joindre le backend admin.', 'error');
        }
      });

      logoutButton.addEventListener('click', async () => {
        await adminFetch('/admin/logout', { method: 'POST' }).catch(() => {});
        setAuthenticated(false);
        usernameInput.value = '';
        setFeedback(loginFeedback, 'Déconnecté.', 'warning');
      });

      viewButtons.forEach((button) => {
        button.addEventListener('click', () => {
          if (!(button instanceof HTMLButtonElement) || !button.dataset.adminViewTarget) return;
          setActiveView(button.dataset.adminViewTarget);
        });
      });

      menuForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        const feedback = document.querySelector('[data-menu-feedback]');
        if (!(feedback instanceof HTMLElement)) return;
        try {
          const response = await adminFetch('/admin/content/editorial', {
            method: 'PUT',
            body: JSON.stringify(editorialPayload())
          });
          if (!response.ok) throw new Error('menu');
          setFeedback(feedback, 'Carte publiée.', 'success');
          await loadContent();
        } catch (_error) {
          setFeedback(feedback, 'Impossible de publier la carte.', 'error');
        }
      });

      suggestionsForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        const feedback = document.querySelector('[data-suggestions-feedback]');
        if (!(feedback instanceof HTMLElement)) return;
        try {
          const response = await adminFetch('/admin/content/editorial', {
            method: 'PUT',
            body: JSON.stringify(editorialPayload())
          });
          if (!response.ok) throw new Error('suggestions');
          setFeedback(feedback, 'Suggestions publiées.', 'success');
          await loadContent();
        } catch (_error) {
          setFeedback(feedback, 'Impossible de publier les suggestions.', 'error');
        }
      });

      eventForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        const feedback = document.querySelector('[data-event-feedback]');
        const imageInput = field(eventForm, 'image');
        if (!(feedback instanceof HTMLElement) || !(imageInput instanceof HTMLInputElement)) return;
        try {
          const imageUrl = await readImageAsDataUrl(imageInput);
          const response = await adminFetch('/admin/events', {
            method: 'POST',
            body: JSON.stringify({
              title: inputValue(eventForm, 'title').trim(),
              eventDate: inputValue(eventForm, 'eventDate'),
              eventTime: inputValue(eventForm, 'eventTime').trim(),
              summary: inputValue(eventForm, 'summary').trim(),
              imageUrl,
              isPublished: true
            })
          });
          if (!response.ok) throw new Error('event');
          eventForm.reset();
          setFeedback(feedback, 'Événement publié.', 'success');
          await loadContent();
        } catch (_error) {
          setFeedback(feedback, 'Impossible de publier l’événement. Image max 1,8 Mo.', 'error');
        }
      });

      galleryForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        const feedback = document.querySelector('[data-gallery-feedback]');
        const imageInput = field(galleryForm, 'image');
        if (!(feedback instanceof HTMLElement) || !(imageInput instanceof HTMLInputElement)) return;
        try {
          const imageUrl = await readImageAsDataUrl(imageInput);
          const response = await adminFetch('/admin/gallery', {
            method: 'POST',
            body: JSON.stringify({
              title: inputValue(galleryForm, 'title').trim(),
              category: inputValue(galleryForm, 'category'),
              alt: inputValue(galleryForm, 'title').trim(),
              imageUrl,
              isPublished: true
            })
          });
          if (!response.ok) throw new Error('gallery');
          galleryForm.reset();
          setFeedback(feedback, 'Photo ajoutée.', 'success');
          await loadContent();
        } catch (_error) {
          setFeedback(feedback, 'Impossible d’ajouter la photo. Image max 1,8 Mo.', 'error');
        }
      });

      eventsList.addEventListener('click', async (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        const button = target.closest('[data-delete-event]');
        if (!(button instanceof HTMLButtonElement)) return;
        const id = button.dataset.deleteEvent;
        if (!id) return;
        await adminFetch(`/admin/events/${id}`, { method: 'DELETE' });
        await loadContent();
      });

      galleryList.addEventListener('click', async (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        const button = target.closest('[data-delete-gallery]');
        if (!(button instanceof HTMLButtonElement)) return;
        const id = button.dataset.deleteGallery;
        if (!id) return;
        await adminFetch(`/admin/gallery/${id}`, { method: 'DELETE' });
        await loadContent();
      });

      setAuthenticated(false);
      adminFetch('/admin/me')
        .then(async (response) => {
          if (!response.ok) throw new Error('session');
          const session = await response.json();
          setAuthenticated(true, session.username);
          await loadContentOrWarn();
        })
        .catch(() => {
          setFeedback(loginFeedback, 'Connectez-vous pour modifier les contenus.', 'warning');
        });
    };

    document.addEventListener('astro:page-load', initAdminPage);
    initAdminPage();
  })();
</script>
