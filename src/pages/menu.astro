---
import ContentRuntime from '../components/ContentRuntime.astro';
import Icon from '../components/Icon.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { weeklyMenu } from '../data/menu';
import { menuSourceLabel } from '../data/menu-source';

const weeklyFormulaGroups = [
  { key: 'starter', title: 'Entrées', aliases: ['entrée', 'entree'] },
  { key: 'main', title: 'Plats', aliases: ['plat'] },
  { key: 'dessert', title: 'Desserts', aliases: ['dessert'] }
];

const normalizeMenuLabel = (value: string) =>
  value
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '');

const menuSectionId = (title: string) => {
  const normalized = normalizeMenuLabel(title);
  if (normalized.includes('partager')) return 'soir-a-partager';
  if (normalized.includes('douceurs') || normalized.includes('apres-midi')) return 'douceurs-apres-midi';
  return normalized.replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
};

const isSweetsSection = (title: string) => {
  const normalized = normalizeMenuLabel(title);
  return normalized.includes('douceurs') || normalized.includes('apres-midi');
};

const parseWeeklyFormula = (description: string) => {
  const [name = '', detail = ''] = description.split(/\s+-\s+/, 2).map((item) => item.trim());
  return { name, detail };
};

const weeklyFormulaSections = weeklyFormulaGroups
  .map((group) => ({
    title: group.title,
    items: weeklyMenu.formulas
      .filter((formula) => {
        const name = normalizeMenuLabel(formula.name);
        return group.aliases.some((alias) => name.includes(alias));
      })
      .map((formula) => parseWeeklyFormula(formula.description))
      .filter((item) => item.name)
  }))
  .filter((section) => section.items.length);

const hasWeeklyFormula = weeklyFormulaSections.length > 0;
const sweetsSection = weeklyMenu.sections.find((section) => isSweetsSection(section.title));
const ardoiseSections = weeklyMenu.sections.filter((section) => !isSweetsSection(section.title));
---

<BaseLayout
  title="Le menu"
  description="Le menu du moment d’Au Platane, pensé pour évoluer au rythme des semaines et des produits."
>
  <section class="section menu-page">
    <div class="menu-page__intro" data-reveal>
      <p class="eyebrow">Le menu</p>
      <div class="menu-page__brand-chip">
        <img src="/brand/logo-alt-black.jpg" alt="" />
        <span>Bar . Restaurant . Salon de thé</span>
      </div>
      <h1 data-menu-title>{weeklyMenu.title}</h1>
      <p class="lead" data-menu-intro>{weeklyMenu.intro}</p>
    </div>

    <div class="menu-page__meta" data-reveal>
      <span data-menu-period>{weeklyMenu.period}</span>
      <strong data-menu-updated-at>Mis à jour le {weeklyMenu.updatedAt}</strong>
      <p data-menu-source-badge>{menuSourceLabel}</p>
      <a class="menu-scroll-cue" href="#menu-ardoise" aria-label="Voir la carte">
        <Icon name="arrow-right" />
      </a>
    </div>
  </section>

  <section class="section" id="menu-ardoise">
    <div class="menu-sheet">
      <div class="menu-sheet__ardoise">
        <div>
          <p class="eyebrow">L’ardoise du moment</p>
          <h2>Une carte courte, vivante et pensée au rythme du lieu.</h2>
        </div>
        <div class="menu-ardoise-heading__chips">
          <a href="#menu-semaine">Menu de la semaine</a>
          <a href="#douceurs-apres-midi">Les douceurs de l’après-midi</a>
          <a href="#ardoise-du-moment">L’ardoise du moment</a>
        </div>
      </div>

      <section class="weekly-menu-card" id="menu-semaine" data-weekly-menu hidden={!hasWeeklyFormula}>
        <div class="weekly-menu-card__heading">
          <p class="eyebrow">Menu de la semaine</p>
          <h2>17 €</h2>
          <p>Entrée + plat ou plat + dessert</p>
        </div>
        <div class="weekly-menu-card__grid" data-weekly-menu-sections>
          {weeklyFormulaSections.map((section) => (
            <article class="weekly-menu-card__section">
              <h3>{section.title}</h3>
              <ul>
                {section.items.map((item) => (
                  <li>
                    <strong>{item.name}</strong>
                    {item.detail && <span>{item.detail}</span>}
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section class="afternoon-sweets-card" id="douceurs-apres-midi" data-afternoon-sweets hidden={!sweetsSection}>
        <div class="afternoon-sweets-card__heading">
          <p class="eyebrow">Les douceurs de l’après-midi</p>
          <h2>Gâteaux, glaces et pauses sucrées.</h2>
        </div>
        <ul class="afternoon-sweets-card__list" data-afternoon-sweets-list>
          {sweetsSection?.items.map((item) => (
            <li>
              <strong>{item.name}*</strong>
              {item.description && <span>{item.description}</span>}
            </li>
          ))}
        </ul>
        <p class="afternoon-sweets-card__note">* fabrication artisanale par "Sylvie, Biscuits & cie"</p>
      </section>

      <div class="menu-sheet__intro" id="ardoise-du-moment">
        <div>
          <p class="eyebrow">L’ardoise du moment</p>
          <h2>Une cuisine courte, locale et mouvante.</h2>
        </div>
        <ul class="menu-sheet__intro-copy" data-menu-notes>
            {weeklyMenu.notes.map((note) => (
              <li>{note}</li>
            ))}
        </ul>
      </div>

      <div class="menu-columns" data-menu-sections>
        {ardoiseSections.map((section) => (
          <article class="menu-group" id={menuSectionId(section.title)}>
            <h2 class="menu-group__title">{section.title}</h2>
            <ul class="menu-list">
              {section.items.map((item) => (
                <li class="menu-list__item">
                  <div class="menu-list__head">
                    <h3 class="menu-list__name">{item.name}</h3>
                    {'price' in item && item.price && (
                      <span class="menu-list__price">{item.price}</span>
                    )}
                  </div>
                  {item.description && <p class="menu-list__description">{item.description}</p>}
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>

      <div class="menu-sheet__signature">
        <div class="menu-sheet__signature-note">
          <p class="eyebrow">Au Platane</p>
        </div>
        <img src="/brand/logo-horizontal-black.jpg" alt="Au Platane" />
      </div>
    </div>
  </section>

  <section class="section menu-page__footer">
    <div class="button-row" data-reveal>
      <a class="button button--primary" href="/#contact">Prendre contact</a>
      <a class="button button--secondary" href="/">Retour à l’accueil</a>
    </div>
  </section>

  <ContentRuntime />
</BaseLayout>
