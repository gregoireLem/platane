---
import ContactForm from '../components/ContactForm.astro';
import Icon from '../components/Icon.astro';
import ReservationForm from '../components/ReservationForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---

<BaseLayout title="Lieu de vie" description={site.description}>
  <section class="home-hero section">
    <div class="home-hero__copy" data-reveal>
      <h1>Un lieu de vie et de partage autour d’une cuisine locale et de saison.</h1>
      <p class="lead">Un lieu simple et vivant, entre restaurant, bar, salon de thé et petite épicerie de village.</p>

      <div class="button-row">
        <a class="button button--primary" href="#reservation">
          Réserver une table
          <Icon name="calendar" />
        </a>
        <a class="button button--secondary" href="/menu">
          Découvrir le menu
          <Icon name="arrow-right" />
        </a>
      </div>
      <div class="home-hero__tags">
        <span>Restaurant</span>
        <span>Bar</span>
        <span>Salon de thé</span>
        <span>Terrasse</span>
        <span>Epicerie fine locale</span>
        <span>Glaces</span>
      </div>
    </div>

    <figure class="home-hero__media" data-reveal>
      <img
        src="/images/terrasse.png"
        alt="Terrasse animée sous le platane à la tombée du jour"
        loading="eager"
      />
      <figcaption class="home-hero__caption">
        <strong>Terrasse sous le platane</strong>
        <span>Du déjeuner aux soirées d’été.</span>
      </figcaption>
    </figure>
  </section>

  <section class="home-story section">
    <div class="home-story__copy" data-reveal>
      <p class="eyebrow">Le projet</p>
      <h2>Un lieu simple, vivant et ouvert à tous.</h2>
      <p class="lead">
        Restaurant, bar, salon de thé, petite épicerie… Au Platane veut faire vivre un lieu de rencontre simple et chaleureux au cœur du village.
      </p>
      <p>
        Installés à Montréal, nous sommes très attachés à la vie locale, aux villages vivants et aux lieux où l’on prend encore le temps de se retrouver. Pour l’une, Montréal fait partie des souvenirs d’enfance et des racines familiales ; pour l’autre, c’est un village découvert récemment et devenu une évidence.
      </p>
      <p>
        Nous imaginons un bistrot de village vivant toute l’année : une cuisine de saison, des produits du coin, un café le matin, un déjeuner entre habitués, un verre partagé en terrasse ou une soirée conviviale sous le platane.
      </p>
      <p>
        Un lieu simple, sincère et ouvert à tous, pensé pour les habitants, les visiteurs et la vie du village.
      </p>
      <div class="button-row">
        <a class="button button--secondary" href="/menu">Voir le menu</a>
        <a class="button button--secondary" href="#contact">Nous contacter</a>
      </div>
    </div>

    <figure class="home-story__portrait" data-reveal>
      <img src="/images/elisa-flo-new.png" alt="Elisa et Flo devant le platane et la maison du lieu" loading="lazy" />
      <figcaption>
        <strong>Elisa & Flo</strong>
        <span>Attachés au village et à une hospitalité simple, locale et vivante.</span>
      </figcaption>
    </figure>
  </section>

  <section class="section home-spaces">
    <div class="section-heading" data-reveal>
      <p class="eyebrow">Sur place</p>
      <h2>Ce que l’on trouve au Platane.</h2>
    </div>

    <div class="space-grid space-grid--compact">
      {site.spaces.map((space) => (
        <article class="space-card" data-reveal>
          <span class="space-card__icon">
            <Icon name={space.icon} />
          </span>
          <h3>{space.title}</h3>
          <p>{space.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section home-events" id="evenements">
    <div class="section-heading" data-reveal>
      <p class="eyebrow">Événements</p>
      <h2>Un lieu qui s’anime aussi autour de la culture.</h2>
      <p class="lead">
        Concerts, représentations, théâtre, expositions ou rendez-vous simples : Au Platane veut aussi faire vivre le village par ses moments partagés.
      </p>
    </div>

    <div class="pill-list" data-reveal>
      {site.eventHighlights.map((item) => (
        <li>{item}</li>
      ))}
    </div>
  </section>

  <section class="section reservation-section" id="reservation">
    <div class="reservation-panel" data-reveal>
      <div class="reservation-panel__copy">
        <p class="eyebrow">Réservation</p>
        <h2>Réserver une table simplement.</h2>
        <p>
          Envoyez votre demande avec la date, l’heure et le nombre de personnes. Le formulaire
          vérifie les places restantes et l’équipe confirme ensuite la réservation.
        </p>
        <div class="hours-card">
          <strong>Horaires d’ouverture</strong>
          <ul class="hours-list">
            {site.openingHours.map((item) => (
              <li>
                <span>{item.day}</span>
                <strong>{item.hours}</strong>
              </li>
            ))}
          </ul>
        </div>
      </div>
      <ReservationForm />
    </div>
  </section>

  <section class="section contact-section" id="contact">
    <div class="section-heading" data-reveal>
      <p class="eyebrow">Contact</p>
      <h2>Une question ou une demande de groupe&nbsp;?</h2>
    </div>

    <div class="contact-grid">
      <aside class="contact-card" data-reveal>
        <p>
          Utilisez le formulaire ou contactez-nous directement par email ou téléphone.
        </p>

        <div class="contact-list">
          <a href={`mailto:${site.email}`}>
            <Icon name="envelope" />
            <span>{site.email}</span>
          </a>

          <a href={`tel:${site.phoneRaw}`}>
            <Icon name="phone" />
            <span>{site.phoneDisplay}</span>
          </a>

          <a class="contact-list__instagram" href={site.instagramUrl} target="_blank" rel="noreferrer">
            <Icon name="instagram" />
            <span>Instagram</span>
          </a>

          <div class="contact-location">
            <div class="contact-location__line">
              <Icon name="map-pin" />
              <span>{site.location}</span>
            </div>
            <a
              class="contact-location__map"
              href={site.mapsUrl}
              target="_blank"
              rel="noreferrer"
            >
              <Icon name="map-pin" />
              <span>Voir sur Maps</span>
            </a>
          </div>

          <div class="contact-hours">
            <div class="contact-hours__title">
              <Icon name="calendar" />
              <span>Horaires</span>
            </div>
            <ul class="hours-list hours-list--compact">
              {site.openingHours.map((item) => (
                <li>
                  <span>{item.day}</span>
                  <strong>{item.hours}</strong>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </aside>

      <div class="contact-form-card" data-reveal>
        <ContactForm />
      </div>
    </div>

    <div class="contact-map-card" data-reveal>
      <iframe
        src={site.mapsEmbedUrl}
        title={`Carte de ${site.name}`}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>
  </section>
</BaseLayout>
