---
type IconName =
  | 'arrow-right'
  | 'cup'
  | 'envelope'
  | 'fork-knife'
  | 'glass'
  | 'ice-cream'
  | 'leaf'
  | 'map-pin'
  | 'phone'
  | 'spark'
  | 'sun';

const { name, title = '', class: className = '' } = Astro.props as {
  name: IconName;
  title?: string;
  class?: string;
};

const icons: Record<IconName, { viewBox: string; path: string }> = {
  'arrow-right': {
    viewBox: '0 0 24 24',
    path: '<path d="M5 12h14M13 5l7 7-7 7" />'
  },
  cup: {
    viewBox: '0 0 24 24',
    path: '<path d="M5 7h11v3a5 5 0 0 1-5 5H9a4 4 0 0 1-4-4V7Zm11 1h2a2 2 0 0 1 0 4h-2M4 19h12" />'
  },
  envelope: {
    viewBox: '0 0 24 24',
    path: '<path d="M4 7h16v10H4zM4 8l8 6 8-6" />'
  },
  'fork-knife': {
    viewBox: '0 0 24 24',
    path: '<path d="M7 4v8M4 4v4a3 3 0 0 0 6 0V4M7 12v8M16 4c-2 2-3 4.8-3 8v8M16 4v16" />'
  },
  glass: {
    viewBox: '0 0 24 24',
    path: '<path d="M8 4h8l-1.2 6.5a3 3 0 0 1-2.95 2.5h-.7a3 3 0 0 1-2.95-2.5L8 4Zm4 9v7M9 20h6" />'
  },
  'ice-cream': {
    viewBox: '0 0 24 24',
    path: '<path d="M8 11a4 4 0 0 1 8 0v1H8v-1Zm1 1 3 9 3-9M8 12h8" />'
  },
  leaf: {
    viewBox: '0 0 24 24',
    path: '<path d="M19 5c-7 0-12 4-12 10 0 2.2 1.8 4 4 4 6 0 10-5 10-12 0-.7 0-1.3-2-2ZM8 16c2.5-2 5.5-3.5 9-4.5" />'
  },
  'map-pin': {
    viewBox: '0 0 24 24',
    path: '<path d="M12 21s6-5.5 6-11a6 6 0 1 0-12 0c0 5.5 6 11 6 11Zm0-8.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z" />'
  },
  phone: {
    viewBox: '0 0 24 24',
    path: '<path d="M6 4h3l1.5 4-2 1.8a16 16 0 0 0 5 5l1.8-2L20 14v3c0 1.1-.9 2-2 2A16 16 0 0 1 5 6c0-1.1.9-2 2-2Z" />'
  },
  spark: {
    viewBox: '0 0 24 24',
    path: '<path d="m12 3 1.8 4.2L18 9l-4.2 1.8L12 15l-1.8-4.2L6 9l4.2-1.8L12 3ZM5 16l.9 2.1L8 19l-2.1.9L5 22l-.9-2.1L2 19l2.1-.9L5 16Zm14-1 .9 2.1L22 18l-2.1.9L19 21l-.9-2.1L16 18l2.1-.9L19 15Z" />'
  },
  sun: {
    viewBox: '0 0 24 24',
    path: '<path d="M12 4V2m0 20v-2m8-8h2M2 12h2m12.66-5.66 1.41-1.41M5.93 18.07l1.41-1.41m9.32 1.41 1.41 1.41M5.93 5.93l1.41 1.41M12 16a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z" />'
  }
};

const icon = icons[name];
---

<svg
  class:list={['icon', className]}
  viewBox={icon.viewBox}
  fill="none"
  stroke="currentColor"
  stroke-width="1.7"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden={title ? 'false' : 'true'}
  role={title ? 'img' : undefined}
>
  {title && <title>{title}</title>}
  <Fragment set:html={icon.path} />
</svg>
